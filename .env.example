# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — never commit it.

# From @BotFather in Telegram.
TELEGRAM_BOT_TOKEN=

# --- Local Bot API server (2 GB uploads) ---
# Set to 1 to make the bot talk to your local server instead of Telegram's
# cloud (cloud is capped at 50 MB uploads; local server allows up to 2 GB).
USE_LOCAL_BOT_API=1
LOCAL_BOT_API_URL=http://localhost:8081

# Get these from https://my.telegram.org -> "API development tools".
# The local Bot API server (docker-compose.yml) needs them to start.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
